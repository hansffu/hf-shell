{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "strict": true,
    "module": "ES2022",
    "target": "ES2020",
    "lib": ["ES2023"],
    "baseUrl": ".",
    "moduleResolution": "Bundler",
    "skipLibCheck": true,
    "paths": {
      "ags/gtk4": ["types/ags-gtk4.d.ts"],
      "ags/gtk4/app": ["types/ags-gtk4-app.d.ts"],
      "ags/gtk4/jsx-runtime": ["types/ags-gtk4-jsx-runtime.d.ts"],
      "ags/time": ["types/ags-time.d.ts"],
      "gnim": ["types/gnim.d.ts"]
    },
    // "checkJs": true,
    // "allowJs": true,
    "jsx": "react-jsx",
    "jsxImportSource": "ags/gtk4"
  },
  "exclude": ["result", "result-*"]
}
